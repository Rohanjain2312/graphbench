# Neo4j AuraDB Free
NEO4J_URI=neo4j+s://49b936c5.databases.neo4j.io
NEO4J_USERNAME=49b936c5
NEO4J_PASSWORD=<your-neo4j-password-here>

# HuggingFace
HF_TOKEN=<your-hf-token-here>

# Weights and Biases
WANDB_API_KEY=<your-wandb-api-key-here>
WANDB_PROJECT=graphbench

# Model config
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Paths
# Note: FAISS writer appends .faiss and _id_map.json automatically — do NOT include an extension here
FAISS_INDEX_PATH=./data/faiss_index
CHECKPOINT_DIR=./checkpoints

# Logging
LOG_LEVEL=INFO